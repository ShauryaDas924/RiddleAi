# =========================================================
# Frontend Environment Example
# =========================================================
# Vite only exposes variables that start with VITE_ to browser code.
# That means every value in this file should be safe for users to see.
#
# Copy this file to .env later when the student is ready to run the app.
# Never put backend-only secrets in frontend environment files.

# The public URL where the React app will call the FastAPI backend.
VITE_BACKEND_API_URL=

# Public Supabase project URL. This is safe to expose when used correctly.
VITE_SUPABASE_URL=

# Public Supabase anon key. This may be used in the browser later.
# Do not put SUPABASE_SERVICE_ROLE_KEY here.
VITE_SUPABASE_ANON_KEY=

# Beginner checklist:
# [ ] Are all variables prefixed with VITE_?
# [ ] Are backend-only secrets excluded?
# [ ] Is the real .env file kept out of git?
