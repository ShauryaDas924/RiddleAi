# =========================================================
# Dependencies
# =========================================================
node_modules/
frontend/*/node_modules/
backend/.venv/
backend/venv/
venv/
.venv/

# =========================================================
# Production / build output
# =========================================================
dist/
build/
frontend/*/dist/
frontend/*/build/

# =========================================================
# Python cache / build files
# =========================================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
.eggs/
pip-wheel-metadata/

# =========================================================
# Environment variables / secrets
# Keep .env.example files committed
# =========================================================
.env
.env.*
!.env.example
frontend/*/.env
frontend/*/.env.*
!frontend/*/.env.example
backend/.env
backend/.env.*
!backend/.env.example

# =========================================================
# Supabase / database local files
# =========================================================
.supabase/
supabase/.branches/
supabase/.temp/
supabase/.env
database/*.db
database/*.sqlite
database/*.sqlite3
*.db
*.sqlite
*.sqlite3

# =========================================================
# Logs
# =========================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
uvicorn.log
gunicorn.log

# =========================================================
# OS files
# =========================================================
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# =========================================================
# Editor / IDE files
# =========================================================
.vscode/
.idea/
*.swp
*.swo
*.swn

# =========================================================
# Vite / frontend cache
# =========================================================
.vite/
frontend/*/.vite/
.cache/

# =========================================================
# Test / coverage output
# =========================================================
coverage/
frontend/*/coverage/
backend/coverage/
test-results/
playwright-report/

# =========================================================
# Package manager lockfiles
# Keep package-lock.json if this project uses npm.
# Ignore optional package managers not used by this project.
# =========================================================
yarn.lock
pnpm-lock.yaml
bun.lockb

# =========================================================
# Temporary files
# =========================================================
tmp/
temp/
*.tmp
*.bak
*.backup
*.old

# =========================================================
# Local student notes / private scratch files
# =========================================================
notes-private/
scratch/
local-only/