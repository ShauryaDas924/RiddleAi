# =========================================================
# Backend Environment Example
# =========================================================
# Backend environment files may contain private keys because they run on the server.
# Copy this file to .env later and fill in real values only on your machine/server.
# Never commit a real .env file.

# App mode and backend server settings.
APP_ENV=
BACKEND_HOST=
BACKEND_PORT=

# Supabase settings.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Backend-only secrets.
# These must never be placed in frontend/my-react-app/.env.
SUPABASE_SERVICE_ROLE_KEY=
AI_API_KEY=
AI_MODEL_NAME=

# Beginner checklist:
# [ ] Are real secrets only in backend/.env?
# [ ] Is backend/.env ignored by git?
# [ ] Are public frontend values kept separate from backend-only secrets?
